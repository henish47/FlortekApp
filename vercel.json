{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "npm install",
  "buildCommand": "npm run build:web",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/((?!_expo|assets|icons|favicon.ico|manifest.json|sw.js).*)" ,
      "destination": "/index.html"
    }
  ]
}