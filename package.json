{
  "name": "flortekorderappnew",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@supabase/supabase-js": "^2.108.1",
    "babel-preset-expo": "^56.0.14",
    "expo": "~56.0.12",
    "expo-auth-session": "~56.0.14",
    "expo-constants": "~56.0.17",
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-font": "~56.0.6",
    "expo-image-picker": "~56.0.18",
    "expo-linking": "~56.0.14",
    "expo-notifications": "~56.0.18",
    "expo-print": "~56.0.4",
    "expo-router": "~56.2.11",
    "expo-sharing": "~56.0.18",
    "expo-status-bar": "~56.0.4",
    "expo-web-browser": "~56.0.5",
    "html2pdf.js": "^0.14.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-paper": "^5.15.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.3",
    "zustand": "^5.0.14"
  },
  "scripts": {
  "start": "expo start",
  "android": "expo run:android",
  "ios": "expo run:ios",
  "web": "expo start --web",

  "build:web": "expo export --platform web",

  "electron:start": "electron electron/main.js",
  "electron:build:win": "npm run build:web && electron-builder --win",
  "electron:build:mac": "npm run build:web && electron-builder --mac",
  "electron:build:linux": "npm run build:web && electron-builder --linux",
  "electron:build:all": "npm run build:web && electron-builder --win --mac --linux"
},
  "private": true,
  "build": {
    "appId": "com.flortek.desktop",
    "productName": "Flortek Industries PVT LTD",
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist",
      "!dist/_expo/static/js/android",
      "!dist/_expo/static/js/ios",
      "electron",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/logo.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/logo.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/logo.png"
    }
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "typescript": "~6.0.3"
  }
}
